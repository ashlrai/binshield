# =============================================================================
# BinShield Environment Variables
# =============================================================================
# Copy this file to the appropriate location:
#   apps/web/.env.local    — Frontend
#   apps/api/.env          — API server
#   apps/worker/.env       — Worker daemon
# =============================================================================

# --- Supabase (required for live mode) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- API ---
BINSHIELD_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_BINSHIELD_API_BASE_URL=http://localhost:4000
BINSHIELD_PUBLIC_APP_URL=http://localhost:3000
PORT=4000

# --- Stripe (required for billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- xAI / Grok (required for AI classification) ---
XAI_API_KEY=xai-...
XAI_MODEL=grok-4-1-fast-reasoning

# --- GitHub (required for advisory sync) ---
GITHUB_TOKEN=ghp_...

# --- NVD (optional, increases rate limit for vulnerability data) ---
NVD_API_KEY=

# --- SendGrid (required for email alerts) ---
SENDGRID_API_KEY=SG.
BINSHIELD_SMTP_FROM_EMAIL=alerts@binshield.dev

# --- Worker mode (for apps/worker) ---
# Options: cli, daemon, feed, crawl
BINSHIELD_WORKER_MODE=daemon
