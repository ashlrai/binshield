{
  "name": "@binshield/cli",
  "version": "0.2.0",
  "description": "Zero-dependency CLI for BinShield — audit package dependencies and lockfiles for binary supply-chain risk",
  "keywords": [
    "security",
    "supply-chain",
    "binary-analysis",
    "npm",
    "cli",
    "sbom",
    "vulnerability"
  ],
  "homepage": "https://binshield.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashlar-ai/binshield",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "binshield": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@ashlr/cli-common": "file:../../../ashlr-cli-common",
    "@binshield/package-intelligence": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
