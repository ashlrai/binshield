{
  "name": "binshield",
  "version": "0.1.0",
  "private": true,
  "description": "BinShield — Supply chain security platform that detects malicious npm/PyPI install scripts and native package binaries, classifies behavior with AI, and blocks supply-chain worms before they reach production.",
  "keywords": [
    "security",
    "supply-chain",
    "binary-analysis",
    "npm",
    "pypi",
    "malware-detection",
    "install-scripts",
    "decompilation",
    "sbom",
    "cyclonedx",
    "ghidra",
    "native-binaries",
    "github-action",
    "devops",
    "appsec",
    "vulnerability-scanner",
    "package-security"
  ],
  "homepage": "https://binshield.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashlrai/binshield"
  },
  "author": "Ashlr AI <mason@ashlr.ai>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @binshield/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.2",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
